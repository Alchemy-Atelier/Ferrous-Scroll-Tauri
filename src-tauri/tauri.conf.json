{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ferrous Scroll",
  "version": "0.1.0",
  "identifier": "com.ferrous-scroll",
  "build": {
    "beforeDevCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Ferrous Scroll - 记录卷轴",
        "width": 1200,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com; connect-src 'self' ipc: https://ipc.localhost",
      "devCsp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "shortDescription": "优雅的待办事项管理",
    "longDescription": "一个使用 Rust 和 Tauri 构建的现代化待办事项管理应用",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
